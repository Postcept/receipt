{
  "name": "@postcept/receipt",
  "version": "1.1.2",
  "description": "Independently verify a Postcept Receipt, the signed proof that an AI agent's high-risk action actually happened in the system of record. Runs anywhere, needs only the public key.",
  "license": "MIT",
  "author": "Postcept",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Postcept/receipt.git"
  },
  "homepage": "https://postcept.com",
  "bugs": "https://github.com/Postcept/receipt/issues",
  "keywords": [
    "postcept",
    "receipt",
    "verification",
    "ed25519",
    "signature",
    "proof-of-completion",
    "ai-agents",
    "transparency-log",
    "merkle"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": "./schema/receipt.schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schema",
    "SPEC.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "npm run build && node --test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0"
  },
  "devDependencies": {
    "typescript": "^5.5.3"
  }
}
